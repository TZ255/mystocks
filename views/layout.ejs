<!DOCTYPE html>
<html lang="sw">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="HisaZangu — Mfumo bora wa kufuatilia hisa zako za Soko la Hisa la Dar es Salaam (DSE). Portfolio, Watchlist, na Arifa za bei.">
  <meta name="keywords" content="DSE, Dar es Salaam Stock Exchange, hisa, Tanzania, stock market, portfolio tracker">
  <meta name="author" content="HisaZangu">
  <meta name="theme-color" content="#0B0F1A">

  <title><%= typeof title !== 'undefined' ? title : 'HisaZangu - Fuatilia Hisa Zako za DSE' %></title>

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="/css/components.css">
  <% if (typeof currentPath !== 'undefined' && currentPath === '/') { %>
    <link rel="stylesheet" href="/css/landing.css">
  <% } %>
  <% if (typeof currentPath !== 'undefined' && currentPath !== '/') { %>
    <link rel="stylesheet" href="/css/dashboard.css">
  <% } %>
</head>
<body>

  <%- include('partials/nav') %>

  <%- include('partials/flash') %>

  <main>
    <%- body %>
  </main>

  <%- include('partials/footer') %>

  <!-- HTMX -->
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>

  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <!-- Custom JS -->
  <script src="/js/app.js"></script>

  <% if (typeof currentPath !== 'undefined' && currentPath === '/') { %>
    <script src="/js/landing.js"></script>
  <% } %>

  <% if (typeof currentPath !== 'undefined' && currentPath !== '/' && typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
    <script src="/js/dashboard.js"></script>
  <% } %>

</body>
</html>
