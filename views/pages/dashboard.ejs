<%
  const dbSummary = typeof portfolioSummary !== 'undefined' ? portfolioSummary : {};
  const dbHoldings = typeof holdings !== 'undefined' ? holdings : [];
  const dbWatchlistStocks = typeof watchlistStocks !== 'undefined' ? watchlistStocks : [];
  const dbAlerts = typeof alerts !== 'undefined' ? alerts : [];
  const dbGainers = typeof gainers !== 'undefined' ? gainers : [];
  const dbLosers = typeof losers !== 'undefined' ? losers : [];
%>

<section class="page-section">
  <div class="container-hisa">

    <!-- Welcome -->
    <div class="mb-4">
      <h1 class="page-title">
        Habari, <span class="text-gold"><%= typeof user !== 'undefined' && user ? user.firstName || user.displayName : '' %></span>
      </h1>
      <p class="text-secondary mb-0" style="font-size:var(--text-sm);">Your portfolio overview and DSE market summary.</p>
    </div>

    <!-- Portfolio Summary -->
    <% if (dbHoldings.length > 0) { %>
      <div class="mb-4">
        <%- include('../partials/portfolio-summary', { portfolioSummary: dbSummary }) %>
      </div>
    <% } else { %>
      <div class="card card-gold mb-4" style="padding:var(--space-5);">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
          <div>
            <h5 class="mb-1" style="font-weight:700;">Start Your Portfolio</h5>
            <p class="text-secondary mb-0" style="font-size:var(--text-sm);">Add your first stock holdings to start tracking your investments.</p>
          </div>
          <a href="/portfolio" class="btn btn-primary btn-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Add Stocks
          </a>
        </div>
      </div>
    <% } %>

    <div class="row g-4">
      <!-- Left Column: Holdings + Watchlist -->
      <div class="col-lg-8">

        <!-- Quick Holdings -->
        <% if (dbSummary.holdings && dbSummary.holdings.length > 0) { %>
          <div class="card mb-4" style="padding:var(--space-5);">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="mb-0" style="font-weight:700;font-size:var(--text-sm);">My Holdings</h6>
              <a href="/portfolio" class="btn btn-link btn-sm" style="font-size:var(--text-xs);">View All</a>
            </div>

            <!-- Mobile -->
            <div class="d-md-none">
              <% dbSummary.holdings.slice(0, 5).forEach(function(h) { %>
                <%
                  const hGain = (h.gainPercent || 0) >= 0;
                  const hColor = hGain ? 'var(--green)' : 'var(--red)';
                  const hPrefix = hGain ? '+' : '';
                %>
                <a href="/stocks/<%= h.symbol %>" class="d-flex justify-content-between align-items-center py-2" style="text-decoration:none;color:var(--text-primary);border-bottom:1px solid var(--border-default);">
                  <div>
                    <span class="fw-700" style="font-size:var(--text-sm);color:var(--text-primary);"><%= h.symbol %></span>
                    <span class="d-block" style="font-size:10px;color:var(--text-secondary);"><%= h.shares.toLocaleString('en-TZ') %> shares</span>
                  </div>
                  <div class="text-end">
                    <span class="tabular-nums fw-600" style="font-size:var(--text-sm);color:var(--text-primary);"><%= h.currentPrice ? h.currentPrice.toLocaleString('en-TZ') : '0' %></span>
                    <span class="d-block tabular-nums" style="font-size:10px;color:<%= hColor %>;"><%= hPrefix %><%= (h.gainPercent || 0).toFixed(2) %>%</span>
                  </div>
                </a>
              <% }); %>
            </div>

            <!-- Desktop -->
            <div class="d-none d-md-block" style="border:none;">
              <table class="table mb-0" style="background:transparent;--bs-table-bg:transparent;">
                <thead>
                  <tr>
                    <th>Stock</th>
                    <th class="text-end">Price</th>
                    <th class="text-end">Shares</th>
                    <th class="text-end">P&L</th>
                  </tr>
                </thead>
                <tbody>
                  <% dbSummary.holdings.slice(0, 5).forEach(function(h) { %>
                    <%
                      const hGain = (h.gainPercent || 0) >= 0;
                      const hColor = hGain ? 'var(--green)' : 'var(--red)';
                      const hPrefix = hGain ? '+' : '';
                    %>
                    <tr style="cursor:pointer;color:var(--text-primary);" onclick="window.location='/stocks/<%= h.symbol %>'">
                      <td><span class="fw-700" style="font-size:var(--text-sm);color:var(--text-primary);"><%= h.symbol %></span></td>
                      <td class="text-end tabular-nums" style="font-size:var(--text-sm);color:var(--text-primary);"><%= h.currentPrice ? h.currentPrice.toLocaleString('en-TZ') : '0' %></td>
                      <td class="text-end tabular-nums" style="font-size:var(--text-sm);color:var(--text-primary);"><%= h.shares.toLocaleString('en-TZ') %></td>
                      <td class="text-end">
                        <span class="tabular-nums fw-600" style="font-size:var(--text-sm);color:<%= hColor %>;"><%= hPrefix %><%= (h.gainPercent || 0).toFixed(2) %>%</span>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        <% } %>

        <!-- Watchlist -->
        <div class="card" style="padding:var(--space-5);">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="mb-0 d-flex align-items-center gap-2" style="font-weight:700;font-size:var(--text-sm);">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
              Watchlist
            </h6>
            <a href="/watchlist" class="btn btn-link btn-sm" style="font-size:var(--text-xs);">View All</a>
          </div>
          <div
            hx-get="/api/watchlist/items"
            hx-trigger="load"
            hx-swap="innerHTML"
            hx-indicator="#watchlist-loader"
          >
            <div class="text-center py-4" id="watchlist-loader">
              <span class="spinner spinner-sm"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Market + Alerts -->
      <div class="col-lg-4">

        <!-- Gainers -->
        <div class="card mb-3" style="padding:var(--space-4);">
          <h6 class="d-flex align-items-center gap-2 mb-3" style="font-size:var(--text-xs);color:var(--green);font-weight:600;text-transform:uppercase;letter-spacing:0.06em;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 17"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
            Top Gainers
          </h6>
          <% if (dbGainers.length === 0) { %>
            <p class="text-muted" style="font-size:var(--text-xs);">No data available.</p>
          <% } else { %>
            <% dbGainers.forEach(function(g) { %>
              <a href="/stocks/<%= g.symbol %>" class="d-flex justify-content-between align-items-center py-2" style="border-bottom:1px solid var(--border-default);text-decoration:none;color:var(--text-primary);">
                <span class="fw-600" style="font-size:var(--text-sm);color:var(--text-primary);"><%= g.symbol %></span>
                <span class="tabular-nums text-green" style="font-size:var(--text-xs);">+<%= g.changePercent ? g.changePercent.toFixed(2) : '0.00' %>%</span>
              </a>
            <% }); %>
          <% } %>
        </div>

        <!-- Losers -->
        <div class="card mb-3" style="padding:var(--space-4);">
          <h6 class="d-flex align-items-center gap-2 mb-3" style="font-size:var(--text-xs);color:var(--red);font-weight:600;text-transform:uppercase;letter-spacing:0.06em;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 18 13.5 8.5 8.5 13.5 1 7"></polyline><polyline points="17 18 23 18 23 12"></polyline></svg>
            Top Losers
          </h6>
          <% if (dbLosers.length === 0) { %>
            <p class="text-muted" style="font-size:var(--text-xs);">No data available.</p>
          <% } else { %>
            <% dbLosers.forEach(function(l) { %>
              <a href="/stocks/<%= l.symbol %>" class="d-flex justify-content-between align-items-center py-2" style="border-bottom:1px solid var(--border-default);text-decoration:none;color:var(--text-primary);">
                <span class="fw-600" style="font-size:var(--text-sm);color:var(--text-primary);"><%= l.symbol %></span>
                <span class="tabular-nums text-red" style="font-size:var(--text-xs);"><%= l.changePercent ? l.changePercent.toFixed(2) : '0.00' %>%</span>
              </a>
            <% }); %>
          <% } %>
        </div>

        <!-- Active Alerts -->
        <div class="card" style="padding:var(--space-4);">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="mb-0 d-flex align-items-center gap-2" style="font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:0.06em;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
              Price Alerts
            </h6>
            <a href="/alerts" class="btn btn-link btn-sm" style="font-size:10px;">Manage</a>
          </div>
          <% if (dbAlerts.length === 0) { %>
            <p class="text-muted" style="font-size:var(--text-xs);">No active alerts.</p>
          <% } else { %>
            <% dbAlerts.slice(0, 5).forEach(function(a) { %>
              <%
                const aTriggered = a.triggered;
                const aCondText = a.condition === 'above' ? 'Above' : 'Below';
                const aStatusColor = aTriggered ? 'var(--green)' : 'var(--gold)';
              %>
              <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom:1px solid var(--border-default);">
                <div>
                  <span class="fw-600" style="font-size:var(--text-sm);"><%= a.symbol %></span>
                  <span class="text-muted" style="font-size:var(--text-xs);"> <%= aCondText %> <%= a.targetPrice.toLocaleString('en-TZ') %></span>
                </div>
                <span style="width:8px;height:8px;border-radius:50%;background:<%= aStatusColor %>;display:inline-block;" title="<%= aTriggered ? 'Triggered' : 'Pending' %>"></span>
              </div>
            <% }); %>
          <% } %>
        </div>

      </div>
    </div>

  </div>
</section>
