<%
  const errCode = typeof code !== 'undefined' ? code : 500;
  const errMsg = typeof message !== 'undefined' ? message : 'Something went wrong. Please try again later.';
%>
<section style="min-height:60vh;display:flex;align-items:center;justify-content:center;padding:var(--space-16) var(--space-6);">
  <div class="text-center">
    <div style="font-size:6rem;font-weight:900;color:var(--gold);line-height:1;margin-bottom:var(--space-4);opacity:0.3;">
      <%= errCode %>
    </div>
    <h1 style="font-size:var(--text-2xl);font-weight:700;margin-bottom:var(--space-4);"><%= typeof title !== 'undefined' ? title : 'Error' %></h1>
    <p class="text-secondary" style="max-width:440px;margin:0 auto var(--space-8);font-size:var(--text-base);"><%= errMsg %></p>
    <a href="/" class="btn btn-primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
      Go Home
    </a>
  </div>
</section>
