<%
  const ldStocks = typeof stocks !== 'undefined' ? stocks : [];
  const ldGainers = typeof gainers !== 'undefined' ? gainers : [];
  const ldLosers = typeof losers !== 'undefined' ? losers : [];
  const ldTotalStocks = typeof totalStocks !== 'undefined' ? totalStocks : 0;
  const ldTotalVolume = typeof totalVolume !== 'undefined' ? totalVolume : 0;
%>

<!-- =====================================================================
     SECTION 1: Hero
     ===================================================================== -->
<section class="hero-section" style="min-height: 100vh; display: flex; align-items: center; position: relative; overflow: hidden;">
  <!-- Background Gradient Orbs -->
  <div class="hero-bg-orb hero-bg-orb-1" style="position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(245,158,11,0.08) 0%,transparent 70%);top:-200px;right:-100px;pointer-events:none;"></div>
  <div class="hero-bg-orb hero-bg-orb-2" style="position:absolute;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(59,130,246,0.06) 0%,transparent 70%);bottom:-150px;left:-100px;pointer-events:none;"></div>
  <!-- Grid pattern overlay -->
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;"></div>

  <div class="container-hisa" style="position:relative;z-index:1;">
    <div class="row align-items-center g-5">
      <div class="col-lg-7">
        <!-- Tagline Badge -->
        <div class="animate-fade-in-up" style="margin-bottom: var(--space-6);">
          <span style="display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border-radius:var(--border-radius-full);background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.2);font-size:var(--text-sm);color:var(--gold);font-weight:500;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 17 18 12 13 7"></polyline><polyline points="6 17 11 12 6 7"></polyline></svg>
            Soko la Hisa la Dar es Salaam
          </span>
        </div>

        <!-- Headline -->
        <h1 class="animate-fade-in-up delay-1" style="font-size: clamp(2.5rem, 5vw, var(--text-6xl)); font-weight: 800; line-height: 1.1; margin-bottom: var(--space-6); letter-spacing: -0.03em;">
          Fuatilia Hisa Zako
          <br>
          <span class="text-gold">za DSE</span>
        </h1>

        <!-- Subtitle -->
        <p class="animate-fade-in-up delay-2" style="font-size: var(--text-lg); color: var(--text-secondary); line-height: var(--leading-relaxed); max-width: 540px; margin-bottom: var(--space-8);">
          Mfumo bora wa kufuatilia hisa zako za Soko la Hisa la Dar es Salaam.
          Portfolio, Watchlist, na Arifa za bei &mdash; yote mahali pamoja.
        </p>

        <!-- CTA Buttons -->
        <div class="d-flex flex-wrap gap-3 animate-fade-in-up delay-3">
          <a href="/auth/google" class="btn-gold-lg animate-pulse-glow" style="display:inline-flex;align-items:center;gap:10px;padding:14px 32px;border-radius:var(--border-radius);font-weight:600;font-size:var(--text-base);color:var(--bg-primary);background:var(--gold);text-decoration:none;transition:all var(--duration) var(--ease-out);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#0B0F1A" opacity="0.7"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#0B0F1A" opacity="0.5"/></svg>
            Anza Sasa &mdash; Bure
          </a>
          <a href="/stocks" style="display:inline-flex;align-items:center;gap:10px;padding:14px 32px;border-radius:var(--border-radius);font-weight:600;font-size:var(--text-base);color:var(--gold);background:transparent;border:1px solid rgba(245,158,11,0.3);text-decoration:none;transition:all var(--duration) var(--ease-out);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg>
            Angalia Hisa
          </a>
        </div>
      </div>

      <!-- Floating Stat Badges -->
      <div class="col-lg-5 d-none d-lg-block" style="position: relative; min-height: 400px;">
        <!-- Stat Badge: Total Stocks -->
        <div class="animate-float animate-fade-in-up delay-3" style="position:absolute;top:40px;right:20px;padding:20px 28px;border-radius:var(--border-radius-lg);background:var(--glass-bg);backdrop-filter:blur(16px);border:1px solid var(--glass-border);box-shadow:var(--shadow-lg);">
          <p class="text-secondary mb-1" style="font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.08em;">Hisa Zilizoorodheshwa</p>
          <span class="tabular-nums fw-800 text-gold" style="font-size: var(--text-4xl);"><%= ldTotalStocks %></span>
          <p class="text-muted mb-0" style="font-size: var(--text-xs);">kwenye DSE</p>
        </div>

        <!-- Stat Badge: Total Volume -->
        <div class="animate-float animate-fade-in-up delay-5" style="position:absolute;bottom:60px;left:0;padding:20px 28px;border-radius:var(--border-radius-lg);background:var(--glass-bg);backdrop-filter:blur(16px);border:1px solid var(--glass-border);box-shadow:var(--shadow-lg);animation-delay:2s;">
          <p class="text-secondary mb-1" style="font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.08em;">Volume ya Leo</p>
          <span class="tabular-nums fw-800 text-blue" style="font-size: var(--text-3xl);"><%= ldTotalVolume.toLocaleString('en-TZ') %></span>
          <p class="text-muted mb-0" style="font-size: var(--text-xs);">hisa zilizouzwa</p>
        </div>

        <!-- Decorative Chart Line -->
        <svg class="animate-fade-in delay-4" viewBox="0 0 300 200" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:280px;opacity:0.15;" preserveAspectRatio="none">
          <polyline points="0,160 30,140 60,150 90,120 120,100 150,110 180,70 210,80 240,40 270,50 300,20" fill="none" stroke="var(--gold)" stroke-width="2"/>
          <linearGradient id="heroGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="var(--gold)" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="var(--gold)" stop-opacity="0"/>
          </linearGradient>
          <polygon points="0,160 30,140 60,150 90,120 120,100 150,110 180,70 210,80 240,40 270,50 300,20 300,200 0,200" fill="url(#heroGrad)"/>
        </svg>
      </div>
    </div>
  </div>
</section>


<!-- =====================================================================
     SECTION 2: Live Market Ticker
     ===================================================================== -->
<section class="ticker-section" style="background: var(--bg-card); border-top: 1px solid var(--border-default); border-bottom: 1px solid var(--border-default); padding: var(--space-4) 0; overflow: hidden;">
  <div
    id="market-ticker"
    hx-get="/api/market/ticker"
    hx-trigger="load"
    hx-swap="innerHTML"
    style="display: flex; white-space: nowrap;"
  >
    <!-- Ticker content loaded via HTMX -->
    <div class="d-flex align-items-center gap-4" style="padding: 0 var(--space-6);">
      <span class="skeleton" style="width:120px;height:20px;display:inline-block;"></span>
      <span class="skeleton" style="width:120px;height:20px;display:inline-block;"></span>
      <span class="skeleton" style="width:120px;height:20px;display:inline-block;"></span>
      <span class="skeleton" style="width:120px;height:20px;display:inline-block;"></span>
      <span class="skeleton" style="width:120px;height:20px;display:inline-block;"></span>
    </div>
  </div>
</section>


<!-- =====================================================================
     SECTION 3: Feature Showcase
     ===================================================================== -->
<section class="features-section animate-on-scroll" style="padding: var(--space-24) 0;">
  <div class="container-hisa">
    <!-- Section Header -->
    <div class="text-center mb-5">
      <span class="text-gold fw-500" style="font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.1em;">Huduma Zetu</span>
      <h2 class="mt-2" style="font-size: var(--text-4xl); font-weight: 800; letter-spacing: -0.03em;">
        Kila Unachohitaji kwa <span class="text-gold">Uwekezaji Wako</span>
      </h2>
      <p class="text-secondary mx-auto" style="max-width: 500px; font-size: var(--text-base);">
        Zana za kisasa za kufuatilia na kusimamia hisa zako za DSE.
      </p>
    </div>

    <!-- Feature Cards 2x2 -->
    <div class="row g-4">
      <!-- Portfolio Tracking -->
      <div class="col-md-6 animate-on-scroll">
        <div class="feature-card glass" style="border-radius: var(--border-radius-lg); padding: var(--space-8); border: 1px solid var(--border-default); height: 100%; transition: all var(--duration) var(--ease-out);">
          <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:48px;height:48px;border-radius:var(--border-radius);background:rgba(245,158,11,0.1);display:flex;align-items:center;justify-content:center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"></line><line x1="18" y1="20" x2="18" y2="4"></line><line x1="6" y1="20" x2="6" y2="16"></line></svg>
            </div>
            <h5 class="mb-0" style="font-size: var(--text-xl); font-weight: 700;">Ufuatiliaji wa Portfolio</h5>
          </div>
          <p class="text-secondary" style="font-size: var(--text-sm); line-height: var(--leading-relaxed);">
            Ongeza hisa zako, fuatilia thamani ya portfolio yako kwa wakati halisi, na angalia faida au hasara yako kwa urahisi.
          </p>
        </div>
      </div>

      <!-- Live Market Data -->
      <div class="col-md-6 animate-on-scroll">
        <div class="feature-card glass" style="border-radius: var(--border-radius-lg); padding: var(--space-8); border: 1px solid var(--border-default); height: 100%; transition: all var(--duration) var(--ease-out);">
          <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:48px;height:48px;border-radius:var(--border-radius);background:rgba(59,130,246,0.1);display:flex;align-items:center;justify-content:center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg>
            </div>
            <h5 class="mb-0" style="font-size: var(--text-xl); font-weight: 700;">Data ya Soko Hai</h5>
          </div>
          <p class="text-secondary" style="font-size: var(--text-sm); line-height: var(--leading-relaxed);">
            Angalia bei za hisa, volume, na mabadiliko ya kila siku moja kwa moja kutoka Soko la Hisa la Dar es Salaam.
          </p>
        </div>
      </div>

      <!-- Price Alerts -->
      <div class="col-md-6 animate-on-scroll">
        <div class="feature-card glass" style="border-radius: var(--border-radius-lg); padding: var(--space-8); border: 1px solid var(--border-default); height: 100%; transition: all var(--duration) var(--ease-out);">
          <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:48px;height:48px;border-radius:var(--border-radius);background:rgba(16,185,129,0.1);display:flex;align-items:center;justify-content:center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
            </div>
            <h5 class="mb-0" style="font-size: var(--text-xl); font-weight: 700;">Arifa za Bei</h5>
          </div>
          <p class="text-secondary" style="font-size: var(--text-sm); line-height: var(--leading-relaxed);">
            Weka arifa za bei na upokee taarifa mara bei ya hisa inapofika kiwango unachotaka — juu au chini.
          </p>
        </div>
      </div>

      <!-- Watchlist -->
      <div class="col-md-6 animate-on-scroll">
        <div class="feature-card glass" style="border-radius: var(--border-radius-lg); padding: var(--space-8); border: 1px solid var(--border-default); height: 100%; transition: all var(--duration) var(--ease-out);">
          <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:48px;height:48px;border-radius:var(--border-radius);background:rgba(239,68,68,0.1);display:flex;align-items:center;justify-content:center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--red-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </div>
            <h5 class="mb-0" style="font-size: var(--text-xl); font-weight: 700;">Watchlist</h5>
          </div>
          <p class="text-secondary" style="font-size: var(--text-sm); line-height: var(--leading-relaxed);">
            Weka hisa zinazokuvutia kwenye watchlist yako na ufuatilie mwenendo wao kwa urahisi kila siku.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- =====================================================================
     SECTION 4: Market Overview (HTMX Live)
     ===================================================================== -->
<section class="market-section animate-on-scroll" style="padding: var(--space-20) 0; background: rgba(17, 24, 39, 0.3);">
  <div class="container-hisa">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <span class="text-gold fw-500" style="font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.1em;">Soko la Leo</span>
        <h3 class="mt-1" style="font-weight: 700;">Muhtasari wa Soko</h3>
      </div>
      <span class="text-muted" style="font-size: var(--text-xs);">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;margin-right:4px;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
        Inasasishwa kila dakika 1
      </span>
    </div>

    <div
      id="market-overview"
      hx-get="/api/market/overview"
      hx-trigger="load, every 60s"
      hx-swap="innerHTML"
    >
      <!-- Loading placeholder -->
      <div class="row g-3">
        <div class="col-6 col-md-3"><div class="skeleton" style="height:100px;border-radius:var(--border-radius);"></div></div>
        <div class="col-6 col-md-3"><div class="skeleton" style="height:100px;border-radius:var(--border-radius);"></div></div>
        <div class="col-6 col-md-3"><div class="skeleton" style="height:100px;border-radius:var(--border-radius);"></div></div>
        <div class="col-6 col-md-3"><div class="skeleton" style="height:100px;border-radius:var(--border-radius);"></div></div>
      </div>
    </div>
  </div>
</section>


<!-- =====================================================================
     SECTION 5: How It Works
     ===================================================================== -->
<section class="how-it-works-section animate-on-scroll" style="padding: var(--space-24) 0;">
  <div class="container-hisa">
    <div class="text-center mb-5">
      <span class="text-gold fw-500" style="font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.1em;">Jinsi Inavyofanya Kazi</span>
      <h2 class="mt-2" style="font-size: var(--text-4xl); font-weight: 800; letter-spacing: -0.03em;">
        Hatua <span class="text-gold">3</span> Rahisi
      </h2>
    </div>

    <div class="row g-4">
      <!-- Step 1 -->
      <div class="col-md-4 animate-on-scroll">
        <div class="text-center" style="padding: var(--space-8);">
          <div style="width:72px;height:72px;border-radius:50%;background:rgba(245,158,11,0.1);border:2px solid rgba(245,158,11,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto var(--space-6);position:relative;">
            <span class="text-gold fw-800" style="font-size: var(--text-2xl);">1</span>
          </div>
          <h5 class="mb-3" style="font-weight: 700;">Ingia na Google</h5>
          <p class="text-secondary" style="font-size: var(--text-sm); max-width: 280px; margin: 0 auto;">
            Bonyeza kitufe kimoja tu na utumie akaunti yako ya Google kuingia. Hakuna nenosiri la kukumbuka.
          </p>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="col-md-4 animate-on-scroll">
        <div class="text-center" style="padding: var(--space-8);">
          <div style="width:72px;height:72px;border-radius:50%;background:rgba(59,130,246,0.1);border:2px solid rgba(59,130,246,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto var(--space-6);">
            <span class="text-blue fw-800" style="font-size: var(--text-2xl);">2</span>
          </div>
          <h5 class="mb-3" style="font-weight: 700;">Ongeza Hisa Zako</h5>
          <p class="text-secondary" style="font-size: var(--text-sm); max-width: 280px; margin: 0 auto;">
            Ongeza hisa unazomiliki kwenye portfolio yako na uweke bei uliyonunulia. Ni rahisi!
          </p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="col-md-4 animate-on-scroll">
        <div class="text-center" style="padding: var(--space-8);">
          <div style="width:72px;height:72px;border-radius:50%;background:rgba(16,185,129,0.1);border:2px solid rgba(16,185,129,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto var(--space-6);">
            <span class="text-green fw-800" style="font-size: var(--text-2xl);">3</span>
          </div>
          <h5 class="mb-3" style="font-weight: 700;">Fuatilia Kila Siku</h5>
          <p class="text-secondary" style="font-size: var(--text-sm); max-width: 280px; margin: 0 auto;">
            Angalia thamani ya portfolio yako ikibadilika kwa wakati halisi. Pokea arifa za bei muhimu.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- =====================================================================
     SECTION 6: DSE Stocks Preview Table
     ===================================================================== -->
<section class="stocks-preview-section animate-on-scroll" style="padding: var(--space-20) 0; background: rgba(17, 24, 39, 0.3);">
  <div class="container-hisa">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <span class="text-gold fw-500" style="font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.1em;">Hisa za DSE</span>
        <h3 class="mt-1" style="font-weight: 700;">Bei za Hisa Leo</h3>
      </div>
      <a href="/stocks" class="d-flex align-items-center gap-2 text-gold" style="font-size: var(--text-sm); font-weight: 600; text-decoration: none;">
        Angalia Zote
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </a>
    </div>

    <div class="glass" style="border-radius: var(--border-radius-lg); border: 1px solid var(--border-default); overflow: hidden;">
      <div class="table-responsive">
        <table class="table table-dark table-hover mb-0" style="background: transparent;">
          <thead>
            <tr style="border-bottom: 1px solid var(--border-default);">
              <th style="padding:var(--space-4) var(--space-5);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;color:var(--text-secondary);font-weight:600;background:rgba(255,255,255,0.02);">Hisa</th>
              <th style="padding:var(--space-4) var(--space-5);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;color:var(--text-secondary);font-weight:600;background:rgba(255,255,255,0.02);">Kampuni</th>
              <th class="text-end" style="padding:var(--space-4) var(--space-5);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;color:var(--text-secondary);font-weight:600;background:rgba(255,255,255,0.02);">Bei (TZS)</th>
              <th class="text-end" style="padding:var(--space-4) var(--space-5);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;color:var(--text-secondary);font-weight:600;background:rgba(255,255,255,0.02);">Badiliko</th>
              <th class="text-end" style="padding:var(--space-4) var(--space-5);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;color:var(--text-secondary);font-weight:600;background:rgba(255,255,255,0.02);">%</th>
              <th class="text-end d-none d-md-table-cell" style="padding:var(--space-4) var(--space-5);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;color:var(--text-secondary);font-weight:600;background:rgba(255,255,255,0.02);">Volume</th>
            </tr>
          </thead>
          <tbody
            id="stocks-preview-body"
            hx-get="/api/stocks/table?limit=10"
            hx-trigger="load"
            hx-swap="innerHTML"
          >
            <!-- Loading placeholders -->
            <% for (let i = 0; i < 5; i++) { %>
              <tr>
                <td style="padding:var(--space-3) var(--space-5);"><div class="skeleton" style="width:60px;height:16px;"></div></td>
                <td style="padding:var(--space-3) var(--space-5);"><div class="skeleton" style="width:140px;height:16px;"></div></td>
                <td style="padding:var(--space-3) var(--space-5);"><div class="skeleton" style="width:80px;height:16px;margin-left:auto;"></div></td>
                <td style="padding:var(--space-3) var(--space-5);"><div class="skeleton" style="width:60px;height:16px;margin-left:auto;"></div></td>
                <td style="padding:var(--space-3) var(--space-5);"><div class="skeleton" style="width:50px;height:16px;margin-left:auto;"></div></td>
                <td class="d-none d-md-table-cell" style="padding:var(--space-3) var(--space-5);"><div class="skeleton" style="width:70px;height:16px;margin-left:auto;"></div></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>


<!-- =====================================================================
     SECTION 7: CTA Section
