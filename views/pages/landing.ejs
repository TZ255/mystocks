<%
  const ldTotalStocks = typeof totalStocks !== 'undefined' ? totalStocks : 0;
  const ldTotalVolume = typeof totalVolume !== 'undefined' ? totalVolume : 0;
%>

<!-- =====================================================================
     SECTION 1: Hero
     ===================================================================== -->
<section class="hero-section">
  <!-- Background Gradient Orbs -->
  <div class="hero-bg-orb hero-bg-orb-1"></div>
  <div class="hero-bg-orb hero-bg-orb-2"></div>
  <!-- Grid pattern overlay -->
  <div class="hero-grid-overlay"></div>

  <div class="container-hisa" style="position:relative;z-index:1;">
    <div class="row align-items-center g-5">
      <div class="col-lg-7">
        <!-- Tagline Badge -->
        <div class="animate-fade-in-up" style="margin-bottom: var(--space-6);">
          <span class="hero-badge-tag">
            <i class="fa-solid fa-chart-line" aria-hidden="true"></i>
            Soko la Hisa la Dar es Salaam
          </span>
        </div>

        <!-- Headline -->
        <h1 class="hero-heading animate-fade-in-up delay-1">
          Fuatilia Hisa Zako za Tanzania
          <br>
          <span class="text-gold">kwa DSE Portfolio Tracker</span>
        </h1>

        <!-- Subtitle -->
        <p class="hero-subtitle-text animate-fade-in-up delay-2">
          HisaZangu ni jukwaa la kufuatilia hisa za Dar es Salaam Stock Exchange (DSE),
          kusimamia portfolio, ku-build watchlist, na kuweka price alerts.
          Tumia data ya soko la Tanzania kufanya maamuzi bora kila siku.
        </p>

        <!-- CTA Buttons -->
        <div class="hero-cta-buttons animate-fade-in-up delay-3">
          <a href="/auth/google" class="hero-cta-primary animate-pulse-glow">
            <i class="fa-brands fa-google" aria-hidden="true"></i>
            Anza Sasa &mdash; Bure
          </a>
          <a href="/stocks" class="hero-cta-secondary">
            <i class="fa-solid fa-arrow-trend-up" aria-hidden="true"></i>
            Angalia DSE Stocks
          </a>
        </div>
      </div>

      <!-- Floating Stat Badges -->
      <div class="col-lg-5 d-none d-lg-block" style="position: relative; min-height: 400px;">
        <div class="animate-float animate-fade-in-up delay-3" style="position:absolute;top:40px;right:20px;padding:20px 28px;border-radius:var(--border-radius-lg);background:var(--glass-bg);backdrop-filter:blur(16px);border:1px solid var(--glass-border);box-shadow:var(--shadow-lg);">
          <p class="text-secondary mb-1" style="font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.08em;">Hisa Zilizoorodheshwa</p>
          <span class="tabular-nums fw-800 text-gold" style="font-size: var(--text-4xl);"><%= ldTotalStocks %></span>
          <p class="text-muted mb-0" style="font-size: var(--text-xs);">kwenye DSE</p>
        </div>

        <div class="animate-float animate-fade-in-up delay-5" style="position:absolute;bottom:60px;left:0;padding:20px 28px;border-radius:var(--border-radius-lg);background:var(--glass-bg);backdrop-filter:blur(16px);border:1px solid var(--glass-border);box-shadow:var(--shadow-lg);animation-delay:2s;">
          <p class="text-secondary mb-1" style="font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.08em;">Volume ya Leo</p>
          <span class="tabular-nums fw-800 text-blue" style="font-size: var(--text-3xl);"><%= ldTotalVolume.toLocaleString('en-TZ') %></span>
          <p class="text-muted mb-0" style="font-size: var(--text-xs);">hisa zilizouzwa</p>
        </div>

        <div class="hero-visual-icon animate-fade-in delay-4" aria-hidden="true">
          <i class="fa-solid fa-chart-line"></i>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- =====================================================================
     SECTION 2: Live Market Ticker
     ===================================================================== -->
<section class="ticker-section" style="background: var(--bg-card); border-top: 1px solid var(--border-default); border-bottom: 1px solid var(--border-default); padding: var(--space-4) 0; overflow: hidden;">
  <div
    id="market-ticker"
    hx-get="/api/market/ticker"
    hx-trigger="load"
    hx-swap="innerHTML"
    hx-indicator="#ticker-loader"
    style="display: flex; white-space: nowrap;"
  >
    <!-- Ticker content loaded via HTMX -->
    <div class="d-flex align-items-center gap-4" style="padding: 0 var(--space-6);">
      <span class="skeleton" style="width:120px;height:20px;display:inline-block;"></span>
      <span class="skeleton" style="width:120px;height:20px;display:inline-block;"></span>
      <span class="skeleton" style="width:120px;height:20px;display:inline-block;"></span>
      <span class="skeleton" style="width:120px;height:20px;display:inline-block;"></span>
      <span class="skeleton" style="width:120px;height:20px;display:inline-block;"></span>
    </div>
  </div>
  <div id="ticker-loader" class="landing-request-indicator htmx-indicator" aria-live="polite" aria-label="Inapakia ticker">
    <span class="spinner spinner-sm"></span>
    <span>Inapakia data ya soko...</span>
  </div>
</section>


<!-- =====================================================================
     SECTION 3: Feature Showcase
     ===================================================================== -->
<section class="features-section landing-section animate-on-scroll">
  <div class="container-hisa">
    <!-- Section Header -->
    <div class="text-center mb-5">
      <span class="text-gold fw-500 landing-section-eyebrow">Huduma Zetu</span>
      <h2 class="mt-2 landing-section-title">
        Kila Unachohitaji kwa <span class="text-gold">DSE Investing</span>
      </h2>
      <p class="text-secondary mx-auto landing-section-desc">
        Zana za kisasa kwa wawekezaji wa Tanzania wanaotaka kufuatilia portfolio performance,
        soko la hisa la DSE, na fursa mpya za uwekezaji.
      </p>
    </div>

    <!-- Feature Cards 2x2 -->
    <div class="row g-3 g-md-4">
      <div class="col-6 col-md-6 animate-on-scroll">
        <div class="feature-card glass landing-feature-card">
          <div class="landing-feature-icon" style="background:rgba(245,158,11,0.1);">
            <i class="fa-solid fa-chart-column" style="color:var(--gold);" aria-hidden="true"></i>
          </div>
          <h5 class="landing-feature-title">Ufuatiliaji wa Portfolio</h5>
          <p class="text-secondary landing-feature-desc">
            Rekodi holdings zako, cost basis, na uone valuation ya portfolio yako ya DSE kwa urahisi.
          </p>
        </div>
      </div>

      <div class="col-6 col-md-6 animate-on-scroll">
        <div class="feature-card glass landing-feature-card">
          <div class="landing-feature-icon" style="background:rgba(59,130,246,0.1);">
            <i class="fa-solid fa-wave-square" style="color:var(--blue);" aria-hidden="true"></i>
          </div>
          <h5 class="landing-feature-title">Data ya Soko Hai</h5>
          <p class="text-secondary landing-feature-desc">
            Angalia DSE share prices, daily change, na market movement za kampuni zilizo-orodheshwa Tanzania.
          </p>
        </div>
      </div>

      <div class="col-6 col-md-6 animate-on-scroll">
        <div class="feature-card glass landing-feature-card">
          <div class="landing-feature-icon" style="background:rgba(16,185,129,0.1);">
            <i class="fa-solid fa-bell" style="color:var(--green);" aria-hidden="true"></i>
          </div>
          <h5 class="landing-feature-title">Arifa za Bei</h5>
          <p class="text-secondary landing-feature-desc">
            Weka price alerts kwa target price yako ili usikose entry point au profit-taking opportunity.
          </p>
        </div>
      </div>

      <div class="col-6 col-md-6 animate-on-scroll">
        <div class="feature-card glass landing-feature-card">
          <div class="landing-feature-icon" style="background:rgba(239,68,68,0.1);">
            <i class="fa-solid fa-eye" style="color:var(--red-light);" aria-hidden="true"></i>
          </div>
          <h5 class="landing-feature-title">Watchlist</h5>
          <p class="text-secondary landing-feature-desc">
            Hifadhi stocks unazofuatilia, linganisha movement zao, na chagua hisa za kuangalia kila siku.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- =====================================================================
     SECTION 4: Market Overview (HTMX Live)
     ===================================================================== -->
<section class="market-section landing-section-alt animate-on-scroll">
  <div class="container-hisa">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-4">
      <div>
        <span class="text-gold fw-500 landing-section-eyebrow">Soko la Leo</span>
        <h3 class="mt-1 landing-subsection-title">Muhtasari wa DSE Market</h3>
      </div>
      <span class="text-muted" style="font-size: var(--text-xs);">
        <i class="fa-regular fa-clock" style="margin-right:4px;" aria-hidden="true"></i>
        Inasasishwa kila dakika 1
      </span>
    </div>

    <div
      id="market-overview"
      hx-get="/api/market/overview"
      hx-trigger="load, every 60s"
      hx-swap="innerHTML"
      hx-indicator="#overview-loader"
    >
      <!-- Loading placeholder -->
      <div class="row g-3">
        <div class="col-6 col-md-3"><div class="skeleton" style="height:100px;border-radius:var(--border-radius);"></div></div>
        <div class="col-6 col-md-3"><div class="skeleton" style="height:100px;border-radius:var(--border-radius);"></div></div>
        <div class="col-6 col-md-3"><div class="skeleton" style="height:100px;border-radius:var(--border-radius);"></div></div>
        <div class="col-6 col-md-3"><div class="skeleton" style="height:100px;border-radius:var(--border-radius);"></div></div>
      </div>
    </div>
    <div id="overview-loader" class="landing-request-indicator htmx-indicator" aria-live="polite" aria-label="Inapakia muhtasari wa soko">
      <span class="spinner spinner-sm"></span>
      <span>Inasasisha muhtasari wa soko...</span>
    </div>
  </div>
</section>


<!-- =====================================================================
     SECTION 5: How It Works
     ===================================================================== -->
<section class="how-it-works-section landing-section animate-on-scroll">
  <div class="container-hisa">
    <div class="text-center mb-5">
      <span class="text-gold fw-500 landing-section-eyebrow">Jinsi Inavyofanya Kazi</span>
      <h2 class="mt-2 landing-section-title">
        Hatua <span class="text-gold">3</span> za Kuanza Kufuatilia Stocks
      </h2>
      <p class="text-secondary mx-auto landing-section-desc">
        Hata kama unaanza leo kwenye uwekezaji wa hisa Tanzania, unaweza kusetup tracking yako ndani ya dakika chache.
      </p>
    </div>

    <div class="row g-4">
      <div class="col-md-4 animate-on-scroll">
        <div class="text-center landing-step-card">
          <div class="landing-step-number" style="background:rgba(245,158,11,0.1);border-color:rgba(245,158,11,0.2);">
            <span class="text-gold fw-800" style="font-size: var(--text-2xl);">1</span>
          </div>
          <h5 class="mb-2" style="font-weight: 700;">Ingia na Google</h5>
          <p class="text-secondary landing-step-desc">
            Fungua akaunti yako haraka bila kujaza form ndefu, kisha anza kutumia DSE tracker papo hapo.
          </p>
        </div>
      </div>

      <div class="col-md-4 animate-on-scroll">
        <div class="text-center landing-step-card">
          <div class="landing-step-number" style="background:rgba(59,130,246,0.1);border-color:rgba(59,130,246,0.2);">
            <span class="text-blue fw-800" style="font-size: var(--text-2xl);">2</span>
          </div>
          <h5 class="mb-2" style="font-weight: 700;">Ongeza Hisa Zako</h5>
          <p class="text-secondary landing-step-desc">
            Ongeza stocks ulizonunua, idadi ya shares, na buying price ili portfolio calculations ziwe sahihi.
          </p>
        </div>
      </div>

      <div class="col-md-4 animate-on-scroll">
        <div class="text-center landing-step-card">
          <div class="landing-step-number" style="background:rgba(16,185,129,0.1);border-color:rgba(16,185,129,0.2);">
            <span class="text-green fw-800" style="font-size: var(--text-2xl);">3</span>
          </div>
          <h5 class="mb-2" style="font-weight: 700;">Fuatilia Kila Siku</h5>
          <p class="text-secondary landing-step-desc">
            Fuatilia price movement, valuation, gain/loss, na alerts kila siku bila kuhamia app nyingi tofauti.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="landing-section animate-on-scroll">
  <div class="container-hisa">
    <div class="row justify-content-center">
      <div class="col-lg-10">
        <div class="glass landing-step-card" style="text-align:left;">
          <span class="text-gold fw-500 landing-section-eyebrow">Kwa Nini HisaZangu</span>
          <h2 class="mt-2 landing-section-title" style="text-align:left;">
            Jukwaa la Kisasa kwa <span class="text-gold">Wawekezaji wa DSE Tanzania</span>
          </h2>
          <p class="text-secondary landing-section-desc" style="max-width:none;text-align:left;">
            Kama unatafuta njia ya kufuatilia DSE stocks, kuona market overview, na kusimamia investment portfolio yako kwa lugha iliyo karibu na mtumiaji wa Tanzania, HisaZangu imejengwa kwa kazi hiyo. Tunachanganya Swahili rahisi na English financial terms kama portfolio, watchlist, price alerts, market data, na valuation ili taarifa ziwe wazi bila kupoteza usahihi wa kifedha.
          </p>
          <p class="text-secondary landing-section-desc" style="max-width:none;text-align:left;margin-bottom:0;">
            Hii inafanya iwe rahisi kwa investor mpya au mwenye uzoefu kufuatilia hisa za Dar es Salaam Stock Exchange, kujua kampuni zipi zinasogea, na kuona mwenendo wa uwekezaji wake siku hadi siku.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- =====================================================================
     SECTION 6: DSE Stocks Preview Table
     ===================================================================== -->
<section class="stocks-preview-section landing-section-alt animate-on-scroll">
  <div class="container-hisa">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <span class="text-gold fw-500 landing-section-eyebrow">Hisa za DSE</span>
        <h3 class="mt-1 landing-subsection-title">Bei za DSE Stocks Leo</h3>
      </div>
      <a href="/stocks" class="d-flex align-items-center gap-2 text-gold" style="font-size: var(--text-sm); font-weight: 600; text-decoration: none;">
        Angalia Stocks Zote
        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
      </a>
    </div>
    <p class="text-secondary landing-section-desc" style="max-width:none;text-align:left;margin-bottom:var(--space-5);">
      Pata muonekano wa haraka wa listed companies, current price, percentage change, na trading volume ili uanze uchambuzi wako wa soko.
    </p>

    <div class="glass" style="border-radius: var(--border-radius-lg); border: 1px solid var(--border-default); overflow: hidden;">
      <div class="table-responsive">
        <table class="table table-dark table-hover mb-0" style="background: transparent;">
          <thead>
            <tr style="border-bottom: 1px solid var(--border-default);">
              <th class="landing-th">Hisa</th>
              <th class="landing-th d-none d-sm-table-cell">Kampuni</th>
              <th class="landing-th text-end">Bei (TZS)</th>
              <th class="landing-th text-end d-none d-sm-table-cell">Badiliko</th>
              <th class="landing-th text-end">%</th>
              <th class="landing-th text-end d-none d-md-table-cell">Volume</th>
            </tr>
          </thead>
          <tbody
            id="stocks-preview-body"
            hx-get="/api/stocks/table?limit=10"
            hx-trigger="load"
            hx-swap="innerHTML"
            hx-indicator="#stocks-table-loader"
          >
            <% for (let i = 0; i < 5; i++) { %>
              <tr>
                <td style="padding:var(--space-3) var(--space-4);"><div class="skeleton" style="width:60px;height:16px;"></div></td>
                <td class="d-none d-sm-table-cell" style="padding:var(--space-3) var(--space-4);"><div class="skeleton" style="width:100px;height:16px;"></div></td>
                <td style="padding:var(--space-3) var(--space-4);"><div class="skeleton" style="width:70px;height:16px;margin-left:auto;"></div></td>
                <td class="d-none d-sm-table-cell" style="padding:var(--space-3) var(--space-4);"><div class="skeleton" style="width:50px;height:16px;margin-left:auto;"></div></td>
                <td style="padding:var(--space-3) var(--space-4);"><div class="skeleton" style="width:45px;height:16px;margin-left:auto;"></div></td>
                <td class="d-none d-md-table-cell" style="padding:var(--space-3) var(--space-4);"><div class="skeleton" style="width:60px;height:16px;margin-left:auto;"></div></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
    <div id="stocks-table-loader" class="landing-request-indicator htmx-indicator" aria-live="polite" aria-label="Inapakia bei za hisa">
      <span class="spinner spinner-sm"></span>
      <span>Inapakia bei za hisa...</span>
    </div>
  </div>
</section>


<section class="landing-section animate-on-scroll">
  <div class="container-hisa">
    <div class="text-center mb-5">
      <span class="text-gold fw-500 landing-section-eyebrow">Maswali Ya Kawaida</span>
      <h2 class="mt-2 landing-section-title">
        FAQ kwa <span class="text-gold">DSE Investors</span>
      </h2>
      <p class="text-secondary mx-auto landing-section-desc">
        Majibu mafupi kwa vitu ambavyo wawekezaji wengi wa Tanzania hutafuta kabla ya kuanza kutumia stock tracker.
      </p>
    </div>

    <div class="row g-4">
      <div class="col-md-6">
        <div class="glass landing-step-card" style="text-align:left;height:100%;">
          <h3 class="landing-subsection-title" style="font-size:var(--text-xl);">HisaZangu ni nini?</h3>
          <p class="text-secondary landing-step-desc" style="margin-bottom:0;">
            Ni DSE portfolio tracker inayokuwezesha kufuatilia hisa za Dar es Salaam Stock Exchange, portfolio value, watchlist, na price alerts sehemu moja.
          </p>
        </div>
      </div>
      <div class="col-md-6">
        <div class="glass landing-step-card" style="text-align:left;height:100%;">
          <h3 class="landing-subsection-title" style="font-size:var(--text-xl);">Naweza kufuatilia hisa za Tanzania kila siku?</h3>
          <p class="text-secondary landing-step-desc" style="margin-bottom:0;">
            Ndiyo. Unaweza kuona market data, daily price movement, na stocks unazozifuatilia ili kuboresha routine yako ya market review.
          </p>
        </div>
      </div>
      <div class="col-md-6">
        <div class="glass landing-step-card" style="text-align:left;height:100%;">
          <h3 class="landing-subsection-title" style="font-size:var(--text-xl);">Watchlist na price alerts vinasaidiaje?</h3>
          <p class="text-secondary landing-step-desc" style="margin-bottom:0;">
            Watchlist hukusaidia kuhifadhi stocks muhimu, huku price alerts zikikusaidia kujua bei inapofika target uliyoweka.
          </p>
        </div>
      </div>
      <div class="col-md-6">
        <div class="glass landing-step-card" style="text-align:left;height:100%;">
          <h3 class="landing-subsection-title" style="font-size:var(--text-xl);">Je, HisaZangu ni broker?</h3>
          <p class="text-secondary landing-step-desc" style="margin-bottom:0;">
            Hapana. HisaZangu ni tool ya tracking na taarifa za soko; haifanyi execution ya trades na si investment advisor.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- =====================================================================
     SECTION 7: CTA Section
     ===================================================================== -->
<section class="cta-section animate-on-scroll" style="padding: var(--space-24) 0;">
  <div class="container-hisa">
    <div class="glass-strong text-center" style="border-radius: var(--border-radius-xl); padding: var(--space-16) var(--space-8); position: relative; overflow: hidden;">
      <!-- Background glow -->
      <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(245,158,11,0.08) 0%,transparent 70%);pointer-events:none;"></div>

      <div style="position: relative; z-index: 1;">
        <h2 style="font-size: var(--text-4xl); font-weight: 800; letter-spacing: -0.03em; margin-bottom: var(--space-4);">
          Anza Kufuatilia <span class="text-gold">Portfolio Yako ya DSE</span> Leo
        </h2>
        <p class="text-secondary mx-auto" style="max-width: 480px; font-size: var(--text-base); margin-bottom: var(--space-8);">
          Jiunge na wawekezaji wa Tanzania wanaotumia HisaZangu kufuatilia DSE stocks, watchlist, na price alerts. Kuanza ni bure.
        </p>
        <a href="/auth/google" class="btn-gold-lg animate-pulse-glow" style="display:inline-flex;align-items:center;gap:10px;padding:16px 40px;border-radius:var(--border-radius);font-weight:600;font-size:var(--text-lg);color:var(--bg-primary);background:var(--gold);text-decoration:none;transition:all var(--duration) var(--ease-out);">
          <i class="fa-brands fa-google" aria-hidden="true"></i>
          Fungua Akaunti kwa Google
        </a>
      </div>
    </div>
  </div>
</section>
