<%
  const wlItems = typeof watchlistItems !== 'undefined' ? watchlistItems : [];
  const wlStocks = typeof stocks !== 'undefined' ? stocks : [];
%>

<section class="page-section">
  <div class="container-hisa">

    <!-- Header -->
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
      <div>
        <h1 class="page-title">Watchlist</h1>
        <p class="text-secondary mb-0" style="font-size:var(--text-sm);">Track your selected stocks and add new ones quickly.</p>
      </div>
      <a href="/stocks" class="btn btn-ghost btn-sm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        Browse Stocks
      </a>
    </div>

    <div class="card mb-4" style="padding:var(--space-5);">
      <h6 class="mb-2" style="font-weight:700;font-size:var(--text-sm);">Quick Add</h6>
      <p class="text-secondary mb-3" style="font-size:var(--text-xs);">Search any stock and tap Watch.</p>
      <div class="search-input-wrapper">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input
          type="text"
          class="search-input"
          id="watchlist-search-input"
          placeholder="Search symbol or company..."
          autocomplete="off"
        >
      </div>
      <div id="watchlist-search-results" class="mt-3 watchlist-search-results"></div>
    </div>

    <script>
      (function() {
        const companies = <%- JSON.stringify(typeof dseCompanies !== 'undefined' ? dseCompanies : {}) %>;
        const input = document.getElementById('watchlist-search-input');
        const resultsDiv = document.getElementById('watchlist-search-results');
        if (!input || !resultsDiv) return;

        input.addEventListener('input', function() {
          const q = this.value.trim().toLowerCase();
          if (!q) { resultsDiv.innerHTML = ''; return; }

          const matches = Object.entries(companies).filter(function(entry) {
            return entry[0].toLowerCase().includes(q) || entry[1].name.toLowerCase().includes(q);
          }).slice(0, 10);

          if (matches.length === 0) {
            resultsDiv.innerHTML = '<div class="text-center text-muted" style="padding:var(--space-4);font-size:var(--text-sm);">No results found.</div>';
            return;
          }

          resultsDiv.innerHTML = matches.map(function(entry) {
            var sym = entry[0], info = entry[1];
            return '<div class="search-result-row">' +
              '<a href="/stocks/' + sym + '" class="search-result-link">' +
                '<div><span class="fw-700" style="font-size:var(--text-sm);color:var(--text-primary);">' + sym + '</span>' +
                '<span class="text-secondary ms-2" style="font-size:var(--text-xs);">' + info.name + '</span></div>' +
                '<div class="text-end"><span class="chip" style="font-size:10px;">' + info.sector + '</span></div>' +
              '</a>' +
              '<button class="btn btn-sm btn-ghost watch-toggle-btn" data-symbol="' + sym + '" data-watched="false"' +
                ' hx-post="/api/watchlist/toggle/' + sym + '" hx-swap="none" hx-indicator="this" type="button">' +
                '<span class="htmx-indicator"><span class="spinner spinner-sm"></span></span>' +
                '<span class="watch-toggle-label">Watch</span>' +
              '</button>' +
            '</div>';
          }).join('');

          htmx.process(resultsDiv);
        });
      })();
    </script>

    <!-- Watchlist Content -->
    <div class="card loading-shell" style="padding:var(--space-5);">
      <div
        id="watchlist-items"
        hx-get="/api/watchlist/items"
        hx-trigger="load, watchlistChanged from:body"
        hx-swap="innerHTML"
        hx-indicator="#wl-loader"
      >
        <div class="text-center py-5" id="wl-loader">
          <span class="spinner"></span>
          <p class="text-muted mt-3" style="font-size:var(--text-sm);">Loading watchlist...</p>
        </div>
      </div>
    </div>

  </div>
</section>
