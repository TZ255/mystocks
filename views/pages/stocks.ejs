<%
  const pgStocks = typeof stocks !== 'undefined' ? stocks : [];
  const pgAuth = typeof isAuthenticated !== 'undefined' ? isAuthenticated : false;
%>

<section class="page-section">
  <div class="container-hisa">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
      <div>
        <h1 class="page-title">DSE Stocks</h1>
        <p class="text-secondary mb-0" style="font-size:var(--text-sm);">All listed stocks on the Dar es Salaam Stock Exchange.</p>
      </div>

      <div class="search-input-wrapper" style="max-width:360px;width:100%;">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input
          type="text"
          class="search-input"
          placeholder="Search stocks..."
          name="q"
          hx-get="/api/search"
          hx-trigger="keyup changed delay:250ms"
          hx-target="#search-results"
          hx-swap="innerHTML"
          hx-indicator="#search-spinner"
          autocomplete="off"
        >
        <span class="htmx-indicator" id="search-spinner" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);"><span class="spinner spinner-sm"></span></span>
        <div id="search-results" class="search-results-panel"></div>
      </div>
    </div>

    <div class="card" style="padding:0;overflow:hidden;">
      <div class="d-md-none">
        <% if (pgStocks.length === 0) { %>
          <div class="text-center py-5">
            <p class="text-muted" style="font-size:var(--text-sm);">No stock data available yet.</p>
          </div>
        <% } else { %>
          <% pgStocks.forEach(function(s) { %>
            <%
              const ch = s.changePercent || 0;
              const isUp = ch > 0;
              const isDown = ch < 0;
              const prefix = isUp ? '+' : '';
              const changeColor = isUp ? 'var(--green)' : isDown ? 'var(--red)' : 'var(--text-muted)';
              const watched = !!s.isWatched;
            %>
            <div class="mobile-stock-row">
              <a href="/stocks/<%= s.symbol %>" class="mobile-stock-link">
                <div>
                  <span class="fw-700" style="font-size:var(--text-sm);color:var(--text-primary);"><%= s.symbol %></span>
                  <span class="d-block text-secondary" style="font-size:10px;"><%= s.companyName || s.symbol %></span>
                </div>
                <div class="text-end">
                  <span class="tabular-nums fw-600" style="font-size:var(--text-sm);color:var(--text-primary);"><%= s.price ? s.price.toLocaleString('en-TZ') : '0' %></span>
                  <span class="d-block tabular-nums" style="font-size:10px;color:<%= changeColor %>;"><%= prefix %><%= ch.toFixed(2) %>%</span>
                </div>
              </a>
              <% if (pgAuth) { %>
                <button
                  class="btn btn-sm <%= watched ? 'btn-primary' : 'btn-ghost' %> watch-toggle-btn"
                  data-symbol="<%= s.symbol %>"
                  data-watched="<%= watched ? 'true' : 'false' %>"
                  hx-post="/api/watchlist/toggle/<%= s.symbol %>"
                  hx-swap="none"
                  hx-indicator="this"
                  type="button"
                >
                  <span class="htmx-indicator"><span class="spinner spinner-sm"></span></span>
                  <span class="watch-toggle-label"><%= watched ? 'Watching' : 'Watch' %></span>
                </button>
              <% } %>
            </div>
          <% }); %>
        <% } %>
      </div>

      <div class="d-none d-md-block table-container" style="border:none;">
        <table class="table mb-0" style="background:transparent;--bs-table-bg:transparent;">
          <thead>
            <tr>
              <th style="padding:var(--space-4) var(--space-5);">Stock</th>
              <th style="padding:var(--space-4) var(--space-5);">Company</th>
              <th class="text-end" style="padding:var(--space-4) var(--space-5);">Price (TZS)</th>
              <th class="text-end" style="padding:var(--space-4) var(--space-5);">Change</th>
              <th class="text-end" style="padding:var(--space-4) var(--space-5);">%</th>
              <th class="text-end d-none d-lg-table-cell" style="padding:var(--space-4) var(--space-5);">Volume</th>
              <th class="text-end d-none d-lg-table-cell" style="padding:var(--space-4) var(--space-5);">Sector</th>
              <% if (pgAuth) { %>
                <th class="text-end" style="padding:var(--space-4) var(--space-5);">Watch</th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% if (pgStocks.length === 0) { %>
              <tr><td colspan="<%= pgAuth ? 8 : 7 %>" class="text-center text-muted" style="padding:var(--space-8);">No stock data available yet.</td></tr>
            <% } else { %>
              <% pgStocks.forEach(function(s) { %>
                <%
                  const ch = s.changePercent || 0;
                  const isUp = ch > 0;
                  const isDown = ch < 0;
                  const colorCls = isUp ? 'text-green' : isDown ? 'text-red' : 'text-muted';
                  const prefix = isUp ? '+' : '';
                  const watched = !!s.isWatched;
                %>
                <tr>
                  <td style="padding:var(--space-3) var(--space-5);">
                    <a href="/stocks/<%= s.symbol %>" style="text-decoration:none;color:var(--text-primary);">
                      <span class="fw-700" style="font-size:var(--text-sm);"><%= s.symbol %></span>
                    </a>
                  </td>
                  <td style="padding:var(--space-3) var(--space-5);"><span class="text-secondary" style="font-size:var(--text-sm);"><%= s.companyName || s.symbol %></span></td>
                  <td class="text-end tabular-nums fw-600" style="padding:var(--space-3) var(--space-5);font-size:var(--text-sm);"><%= s.price ? s.price.toLocaleString('en-TZ') : '0' %></td>
                  <td class="text-end tabular-nums <%= colorCls %>" style="padding:var(--space-3) var(--space-5);font-size:var(--text-sm);"><%= prefix %><%= s.change ? s.change.toFixed(2) : '0.00' %></td>
                  <td class="text-end" style="padding:var(--space-3) var(--space-5);">
                    <span class="badge" style="font-size:var(--text-xs);padding:3px 8px;border-radius:var(--border-radius-full);background:<%= isUp ? 'rgba(16,185,129,0.15)' : isDown ? 'rgba(239,68,68,0.15)' : 'rgba(156,163,175,0.1)' %>;color:<%= isUp ? 'var(--green)' : isDown ? 'var(--red)' : 'var(--text-muted)' %>;"><%= prefix %><%= ch.toFixed(2) %>%</span>
                  </td>
                  <td class="text-end d-none d-lg-table-cell tabular-nums text-secondary" style="padding:var(--space-3) var(--space-5);font-size:var(--text-sm);"><%= s.volume ? s.volume.toLocaleString('en-TZ') : '0' %></td>
                  <td class="text-end d-none d-lg-table-cell" style="padding:var(--space-3) var(--space-5);">
                    <span class="chip" style="font-size:10px;"><%= s.sector || 'N/A' %></span>
                  </td>
                  <% if (pgAuth) { %>
                    <td class="text-end" style="padding:var(--space-3) var(--space-5);">
                      <button
                        class="btn btn-sm <%= watched ? 'btn-primary' : 'btn-ghost' %> watch-toggle-btn"
                        data-symbol="<%= s.symbol %>"
                        data-watched="<%= watched ? 'true' : 'false' %>"
                        hx-post="/api/watchlist/toggle/<%= s.symbol %>"
                        hx-swap="none"
                        hx-indicator="this"
                        type="button"
                      >
                        <span class="htmx-indicator"><span class="spinner spinner-sm"></span></span>
                        <span class="watch-toggle-label"><%= watched ? 'Watching' : 'Watch' %></span>
                      </button>
                    </td>
                  <% } %>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    const input = document.querySelector('.search-input');
    const results = document.getElementById('search-results');
    if (!input || !results) return;

    input.addEventListener('input', function() {
      results.style.display = this.value.trim() ? 'block' : 'none';
    });

    input.addEventListener('blur', function() {
      setTimeout(function() { results.style.display = 'none'; }, 200);
    });

    input.addEventListener('focus', function() {
      if (this.value.trim()) results.style.display = 'block';
    });
  })();
</script>
