<%
  const pfHoldings = typeof holdings !== 'undefined' ? holdings : [];
  const pfStockMap = typeof stockMap !== 'undefined' ? stockMap : {};
  const pfSummary = typeof portfolioSummary !== 'undefined' ? portfolioSummary : {};
  const pfAllStocks = typeof allStocks !== 'undefined' ? allStocks : [];
  const pfTransactions = typeof transactions !== 'undefined' ? transactions : [];
  const today = new Date().toISOString().split('T')[0];
%>

<section class="page-section">
  <div class="container-hisa">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
      <div>
        <h1 class="page-title">My Portfolio</h1>
        <p class="text-secondary mb-0" style="font-size:var(--text-sm);">Manage your DSE stock holdings, buy and sell shares.</p>
      </div>
      <div class="d-none d-md-flex gap-2">
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#buyModal">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          Buy Shares
        </button>
        <button class="btn btn-outline-gold btn-sm" data-bs-toggle="modal" data-bs-target="#sellModal" id="sellBtnDesktop" <%= pfHoldings.length === 0 ? 'disabled' : '' %>>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline></svg>
          Sell Shares
        </button>
      </div>
    </div>

    <div id="portfolio-content-wrap" class="position-relative">
      <div id="portfolio-content">
        <%- include('../fragments/portfolio-content', { holdings: pfHoldings, stockMap: pfStockMap, portfolioSummary: pfSummary, allStocks: pfAllStocks, transactions: pfTransactions }) %>
      </div>
      <div class="portfolio-sync-indicator htmx-indicator" id="portfolio-content-indicator">
        <span class="spinner spinner-sm"></span>
        <span>Syncing portfolio...</span>
      </div>
    </div>
  </div>
</section>

<div class="mobile-portfolio-actions d-md-none">
  <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#buyModal">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
    Buy
  </button>
  <button class="btn btn-outline-gold btn-sm" data-bs-toggle="modal" data-bs-target="#sellModal" id="sellBtnMobile" <%= pfHoldings.length === 0 ? 'disabled' : '' %>>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline></svg>
    Sell
  </button>
</div>

<div class="modal fade" id="buyModal" tabindex="-1" aria-labelledby="buyModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-fullscreen-sm-down">
    <div class="modal-content" style="background:var(--bg-card);border:1px solid var(--border-default);border-radius:var(--border-radius-lg);">
      <div class="modal-header" style="border-bottom:1px solid var(--border-default);padding:var(--space-5) var(--space-6);">
        <h5 class="modal-title" id="buyModalLabel" style="font-weight:700;color:var(--text-primary);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          Buy Shares
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" style="padding:var(--space-6);">
        <form
          id="buyForm"
          hx-post="/api/portfolio/add"
          hx-target="#portfolio-content"
          hx-swap="innerHTML"
          hx-indicator="#buy-submit-indicator"
          hx-disabled-elt="find button[type='submit']"
        >
          <div class="mb-3">
            <label class="form-label">Stock</label>
            <select name="symbol" class="form-select" required>
              <option value="">Select stock...</option>
              <% pfAllStocks.forEach(function(s) { %>
                <option value="<%= s.symbol %>"><%= s.symbol %> - <%= s.companyName || s.symbol %></option>
              <% }); %>
            </select>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-6">
              <label class="form-label">Shares</label>
              <input type="number" name="shares" class="form-input" placeholder="100" min="1" required>
            </div>
            <div class="col-6">
              <label class="form-label">Buy Price (TZS)</label>
              <input type="number" name="avgBuyPrice" class="form-input" placeholder="1,500" min="0" step="0.01" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Purchase Date</label>
            <input type="date" name="purchaseDate" class="form-input" value="<%= today %>" max="<%= today %>">
          </div>
          <div class="mb-4">
            <label class="form-label">Notes (optional)</label>
            <input type="text" name="notes" class="form-input" placeholder="e.g. Long-term hold">
          </div>
          <button type="submit" class="btn btn-success w-100">
            <span class="htmx-indicator me-2" id="buy-submit-indicator"><span class="spinner spinner-sm"></span></span>
            Confirm Purchase
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="sellModal" tabindex="-1" aria-labelledby="sellModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-fullscreen-sm-down">
    <div class="modal-content" style="background:var(--bg-card);border:1px solid var(--border-default);border-radius:var(--border-radius-lg);">
      <div class="modal-header" style="border-bottom:1px solid var(--border-default);padding:var(--space-5) var(--space-6);">
        <h5 class="modal-title" id="sellModalLabel" style="font-weight:700;color:var(--text-primary);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px;"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"></polyline><polyline points="16 17 22 17 22 11"></polyline></svg>
          Sell Shares
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" style="padding:var(--space-6);">
        <form
          id="sellForm"
          hx-post="/api/portfolio/sell"
          hx-target="#portfolio-content"
          hx-swap="innerHTML"
          hx-indicator="#sell-submit-indicator"
          hx-disabled-elt="find button[type='submit']"
        >
          <div class="mb-3">
            <label class="form-label">Stock to Sell</label>
            <select name="symbol" class="form-select" required id="sellSymbolSelect">
              <option value="">Select stock...</option>
              <% if (pfSummary.holdings) { pfSummary.holdings.forEach(function(h) { %>
                <option value="<%= h.symbol %>" data-max="<%= h.shares %>"><%= h.symbol %> - <%= h.shares.toLocaleString() %> shares owned</option>
              <% }); } %>
            </select>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-6">
              <label class="form-label">Shares to Sell</label>
              <input type="number" name="shares" class="form-input" placeholder="50" min="1" required id="sellSharesInput">
              <p class="form-helper mt-1" id="sellMaxHint" style="display:none;">Max: <span id="sellMaxValue">0</span> shares</p>
            </div>
            <div class="col-6">
              <label class="form-label">Sell Price (TZS)</label>
              <input type="number" name="sellPrice" class="form-input" placeholder="2,000" min="0" step="0.01" required>
            </div>
          </div>
          <div class="mb-4">
            <label class="form-label">Notes (optional)</label>
            <input type="text" name="notes" class="form-input" placeholder="e.g. Taking profit">
          </div>
          <button type="submit" class="btn btn-danger w-100">
            <span class="htmx-indicator me-2" id="sell-submit-indicator"><span class="spinner spinner-sm"></span></span>
            Confirm Sale
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    function syncSellOptions() {
      const dataEl = document.getElementById('portfolio-holdings-data');
      const select = document.getElementById('sellSymbolSelect');
      const desktopSellBtn = document.getElementById('sellBtnDesktop');
      const mobileSellBtn = document.getElementById('sellBtnMobile');
      if (!dataEl || !select) return;

      let holdings = [];
      try {
        holdings = JSON.parse(dataEl.textContent || '[]');
      } catch (err) {
        holdings = [];
      }

      const previous = select.value;
      const nextOptions = ['<option value="">Select stock...</option>'];
      holdings.forEach(function(h) {
        const shares = Number(h.shares || 0);
        nextOptions.push('<option value="' + h.symbol + '" data-max="' + shares + '">' + h.symbol + ' - ' + shares.toLocaleString() + ' shares owned</option>');
      });
      select.innerHTML = nextOptions.join('');
      if (previous) select.value = previous;

      if (desktopSellBtn) {
        desktopSellBtn.disabled = holdings.length === 0;
      }
      if (mobileSellBtn) {
        mobileSellBtn.disabled = holdings.length === 0;
      }
    }

    const sel = document.getElementById('sellSymbolSelect');
    const inp = document.getElementById('sellSharesInput');
    const hint = document.getElementById('sellMaxHint');
    const maxVal = document.getElementById('sellMaxValue');
    if (!sel || !inp) return;

    function closeModalFully(modalId) {
      const modalEl = document.getElementById(modalId);
      if (!modalEl || typeof bootstrap === 'undefined') return;

      const instance = bootstrap.Modal.getInstance(modalEl) || bootstrap.Modal.getOrCreateInstance(modalEl);

      const cleanup = function() {
        modalEl.classList.remove('show');
        modalEl.style.display = 'none';
        modalEl.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('modal-open');
        document.body.style.removeProperty('padding-right');
        document.querySelectorAll('.modal-backdrop').forEach(function(backdrop) {
          backdrop.remove();
        });
      };

      modalEl.addEventListener('hidden.bs.modal', cleanup, { once: true });
      instance.hide();

      // Fallback in case hidden event is skipped due async swap timing.
      setTimeout(cleanup, 400);
    }

    sel.addEventListener('change', function() {
      const opt = this.options[this.selectedIndex];
      const max = opt.dataset.max;
      if (max) {
        inp.max = max;
        maxVal.textContent = parseInt(max, 10).toLocaleString();
        hint.style.display = 'block';
      } else {
        inp.removeAttribute('max');
        hint.style.display = 'none';
      }
    });

    if (!window.__portfolioGlobalHandlersBound) {
      document.addEventListener('htmx:afterSwap', function(event) {
        if (event.detail && event.detail.target && event.detail.target.id === 'portfolio-content') {
          syncSellOptions();
        }
      });

      document.addEventListener('htmx:afterRequest', function(event) {
        if (!event.detail || !event.detail.successful || !event.detail.elt) return;

        if (event.detail.elt.id === 'buyForm') {
          event.detail.elt.reset();
          closeModalFully('buyModal');
        }

        if (event.detail.elt.id === 'sellForm') {
          event.detail.elt.reset();
          closeModalFully('sellModal');
        }
      });

      window.__portfolioGlobalHandlersBound = true;
    }

    syncSellOptions();
  })();
</script>
