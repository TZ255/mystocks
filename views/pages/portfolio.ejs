<%
  const pfHoldings = typeof holdings !== 'undefined' ? holdings : [];
  const pfStockMap = typeof stockMap !== 'undefined' ? stockMap : {};
  const pfSummary = typeof portfolioSummary !== 'undefined' ? portfolioSummary : {};
  const pfAllStocks = typeof allStocks !== 'undefined' ? allStocks : [];
  const today = new Date().toISOString().split('T')[0];
%>

<section class="page-section">
  <div class="container-hisa">

    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
      <div>
        <h1 class="page-title">My Portfolio</h1>
        <p class="text-secondary mb-0" style="font-size:var(--text-sm);">Manage your DSE stock holdings, buy and sell shares.</p>
      </div>
      <div class="d-flex gap-2">
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#buyModal">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          Buy Shares
        </button>
        <% if (pfHoldings.length > 0) { %>
          <button class="btn btn-outline-gold btn-sm" data-bs-toggle="modal" data-bs-target="#sellModal">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline></svg>
            Sell Shares
          </button>
        <% } %>
      </div>
    </div>

    <!-- Portfolio Summary + Charts -->
    <% if (pfHoldings.length > 0) { %>
      <div class="row g-4 mb-4">
        <div class="col-lg-8">
          <%- include('../partials/portfolio-summary', { portfolioSummary: pfSummary }) %>
        </div>
        <div class="col-lg-4">
          <div class="card h-100" style="padding:var(--space-5);">
            <h6 class="mb-3" style="font-weight:600;font-size:var(--text-sm);color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.06em;">Allocation</h6>
            <div id="allocation-chart" style="position:relative;height:200px;display:flex;align-items:center;justify-content:center;">
              <canvas id="allocationCanvas"></canvas>
            </div>
            <% if (pfSummary.sectorData && pfSummary.sectorData.length > 0) { %>
              <div style="margin-top:var(--space-4);">
                <% pfSummary.sectorData.forEach(function(s, i) { %>
                  <div class="d-flex justify-content-between align-items-center" style="padding:4px 0;font-size:var(--text-xs);">
                    <div class="d-flex align-items-center gap-2">
                      <span style="width:8px;height:8px;border-radius:50%;background:var(--chart-color-<%= i %>);display:inline-block;"></span>
                      <span class="text-secondary"><%= s.sector %></span>
                    </div>
                    <span class="tabular-nums fw-600" style="color:var(--text-primary);"><%= s.percent %>%</span>
                  </div>
                <% }); %>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="card card-gold mb-4" style="padding:var(--space-8);text-align:center;">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto var(--space-4);display:block;"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path></svg>
        <h5 class="mb-2" style="font-weight:700;">Start Your Portfolio</h5>
        <p class="text-secondary mb-4" style="font-size:var(--text-sm);max-width:400px;margin:0 auto;">Add your first stock holding to start tracking your investments on the DSE.</p>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#buyModal">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          Add First Stock
        </button>
      </div>
    <% } %>

    <!-- Holdings -->
    <div class="card" style="padding:var(--space-5);">
      <div id="portfolio-holdings">
        <%- include('../fragments/portfolio-holdings', { holdings: pfHoldings, stockMap: pfStockMap, portfolioSummary: pfSummary, allStocks: pfAllStocks }) %>
      </div>
    </div>

  </div>
</section>

<!-- Buy Modal -->
<div class="modal fade" id="buyModal" tabindex="-1" aria-labelledby="buyModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="background:var(--bg-card);border:1px solid var(--border-default);border-radius:var(--border-radius-lg);">
      <div class="modal-header" style="border-bottom:1px solid var(--border-default);padding:var(--space-5) var(--space-6);">
        <h5 class="modal-title" id="buyModalLabel" style="font-weight:700;color:var(--text-primary);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          Buy Shares
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" style="padding:var(--space-6);">
        <form
          hx-post="/api/portfolio/add"
          hx-target="#portfolio-holdings"
          hx-swap="innerHTML"
          hx-indicator="#buy-indicator"
          hx-on::after-request="if(event.detail.successful){this.reset();bootstrap.Modal.getInstance(document.getElementById('buyModal')).hide();}"
        >
          <div class="mb-3">
            <label class="form-label">Stock</label>
            <select name="symbol" class="form-select" required>
              <option value="">Select stock...</option>
              <% pfAllStocks.forEach(function(s) { %>
                <option value="<%= s.symbol %>"><%= s.symbol %> — <%= s.companyName || s.symbol %></option>
              <% }); %>
            </select>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-6">
              <label class="form-label">Shares</label>
              <input type="number" name="shares" class="form-input" placeholder="100" min="1" required>
            </div>
            <div class="col-6">
              <label class="form-label">Buy Price (TZS)</label>
              <input type="number" name="avgBuyPrice" class="form-input" placeholder="1,500" min="0" step="0.01" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Purchase Date</label>
            <input type="date" name="purchaseDate" class="form-input" value="<%= today %>" max="<%= today %>">
          </div>
          <div class="mb-4">
            <label class="form-label">Notes (optional)</label>
            <input type="text" name="notes" class="form-input" placeholder="e.g. Long-term hold">
          </div>
          <button type="submit" class="btn btn-success w-100">
            <span class="htmx-indicator me-2" id="buy-indicator"><span class="spinner spinner-sm"></span></span>
            Confirm Purchase
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Sell Modal -->
<div class="modal fade" id="sellModal" tabindex="-1" aria-labelledby="sellModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="background:var(--bg-card);border:1px solid var(--border-default);border-radius:var(--border-radius-lg);">
      <div class="modal-header" style="border-bottom:1px solid var(--border-default);padding:var(--space-5) var(--space-6);">
        <h5 class="modal-title" id="sellModalLabel" style="font-weight:700;color:var(--text-primary);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px;"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"></polyline><polyline points="16 17 22 17 22 11"></polyline></svg>
          Sell Shares
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" style="padding:var(--space-6);">
        <form
          hx-post="/api/portfolio/sell"
          hx-target="#portfolio-holdings"
          hx-swap="innerHTML"
          hx-indicator="#sell-indicator"
          hx-on::after-request="if(event.detail.successful){this.reset();bootstrap.Modal.getInstance(document.getElementById('sellModal')).hide();}"
        >
          <div class="mb-3">
            <label class="form-label">Stock to Sell</label>
            <select name="symbol" class="form-select" required id="sellSymbolSelect">
              <option value="">Select stock...</option>
              <% if (pfSummary.holdings) { pfSummary.holdings.forEach(function(h) { %>
                <option value="<%= h.symbol %>" data-max="<%= h.shares %>"><%= h.symbol %> — <%= h.shares.toLocaleString() %> shares owned</option>
              <% }); } %>
            </select>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-6">
              <label class="form-label">Shares to Sell</label>
              <input type="number" name="shares" class="form-input" placeholder="50" min="1" required id="sellSharesInput">
              <p class="form-helper mt-1" id="sellMaxHint" style="display:none;">Max: <span id="sellMaxValue">0</span> shares</p>
            </div>
            <div class="col-6">
              <label class="form-label">Sell Price (TZS)</label>
              <input type="number" name="sellPrice" class="form-input" placeholder="2,000" min="0" step="0.01" required>
            </div>
          </div>
          <div class="mb-4">
            <label class="form-label">Notes (optional)</label>
            <input type="text" name="notes" class="form-input" placeholder="e.g. Taking profit">
          </div>
          <button type="submit" class="btn btn-danger w-100">
            <span class="htmx-indicator me-2" id="sell-indicator"><span class="spinner spinner-sm"></span></span>
            Confirm Sale
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  // Update max shares hint when sell stock selection changes
  (function() {
    const sel = document.getElementById('sellSymbolSelect');
    const inp = document.getElementById('sellSharesInput');
    const hint = document.getElementById('sellMaxHint');
    const maxVal = document.getElementById('sellMaxValue');
    if (!sel || !inp) return;

    sel.addEventListener('change', function() {
      const opt = this.options[this.selectedIndex];
      const max = opt.dataset.max;
      if (max) {
        inp.max = max;
        maxVal.textContent = parseInt(max).toLocaleString();
        hint.style.display = 'block';
      } else {
        inp.removeAttribute('max');
        hint.style.display = 'none';
      }
    });
  })();
</script>
