<%
  const sr = typeof results !== 'undefined' ? results : [];
  const isAuth = typeof isAuthenticated !== 'undefined' ? isAuthenticated : false;
  const watchedSymbols = typeof watchedSymbols !== 'undefined' ? watchedSymbols : [];
  const watchedSet = new Set(watchedSymbols);
%>

<% if (sr.length === 0) { %>
  <div class="text-center text-muted" style="padding:var(--space-4);font-size:var(--text-sm);">
    No results found.
  </div>
<% } else { %>
  <% sr.forEach(function(s) { %>
    <%
      const ch = s.changePercent || 0;
      const isUp = ch > 0;
      const prefix = isUp ? '+' : '';
      const isWatched = watchedSet.has(s.symbol);
    %>
    <div class="search-result-row">
      <a href="/stocks/<%= s.symbol %>" class="search-result-link">
        <div>
          <span class="fw-700" style="font-size:var(--text-sm);color:var(--text-primary);"><%= s.symbol %></span>
          <span class="text-secondary ms-2" style="font-size:var(--text-xs);"><%= s.companyName || '' %></span>
        </div>
        <div class="text-end">
          <span class="tabular-nums fw-600" style="font-size:var(--text-sm);color:var(--text-primary);"><%= s.price ? s.price.toLocaleString('en-TZ') : '0' %></span>
          <span class="tabular-nums ms-2" style="font-size:var(--text-xs);color:<%= isUp ? 'var(--green)' : ch < 0 ? 'var(--red)' : 'var(--text-muted)' %>;">
            <%= prefix %><%= ch.toFixed(2) %>%
          </span>
        </div>
      </a>

      <% if (isAuth) { %>
        <button
          class="btn btn-sm <%= isWatched ? 'btn-primary' : 'btn-ghost' %> watch-toggle-btn"
          data-symbol="<%= s.symbol %>"
          data-watched="<%= isWatched ? 'true' : 'false' %>"
          hx-post="/api/watchlist/toggle/<%= s.symbol %>"
          hx-swap="none"
          hx-indicator="this"
          type="button"
        >
          <span class="htmx-indicator"><span class="spinner spinner-sm"></span></span>
          <span class="watch-toggle-label"><%= isWatched ? 'Watching' : 'Watch' %></span>
        </button>
      <% } %>
    </div>
  <% }); %>
<% } %>
