<%
  const cardStock = typeof stock !== 'undefined' ? stock : {};
  const cardChange = cardStock.change || 0;
  const cardChangePercent = cardStock.changePercent || 0;
  const isPositive = cardChange >= 0;
  const colorClass = isPositive ? 'text-green' : 'text-red';
  const arrow = isPositive ? '+' : '';
%>
<div class="stock-card glass" style="border-radius: var(--border-radius); padding: var(--space-5); transition: all var(--duration) var(--ease-out); border: 1px solid var(--border-default);">
  <a href="/stocks/<%= cardStock.symbol %>" style="text-decoration: none; color: inherit; display: block;">
    <div class="d-flex justify-content-between align-items-start mb-3">
      <div>
        <span class="fw-700" style="font-size: var(--text-lg); color: var(--text-primary);"><%= cardStock.symbol %></span>
        <p class="text-secondary mb-0" style="font-size: var(--text-xs); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 160px;">
          <%= cardStock.companyName || cardStock.symbol %>
        </p>
      </div>
      <span class="badge <%= isPositive ? 'badge-green' : 'badge-red' %>" style="font-size: var(--text-xs); padding: 4px 8px; border-radius: var(--border-radius-full); background: <%= isPositive ? 'rgba(16,185,129,0.15)' : 'rgba(239,68,68,0.15)' %>; color: <%= isPositive ? 'var(--green)' : 'var(--red)' %>;">
        <%= arrow %><%= cardChangePercent.toFixed(2) %>%
      </span>
    </div>

    <div class="d-flex justify-content-between align-items-end">
      <div>
        <span class="tabular-nums fw-700" style="font-size: var(--text-2xl); color: var(--text-primary);">
          <%= cardStock.price ? cardStock.price.toLocaleString('en-TZ') : '0' %>
        </span>
        <span class="text-muted" style="font-size: var(--text-xs); margin-left: 4px;">TZS</span>
      </div>
      <div class="text-end">
        <span class="tabular-nums <%= colorClass %>" style="font-size: var(--text-sm);">
          <%= arrow %><%= cardChange.toFixed(2) %>
        </span>
        <% if (cardStock.volume) { %>
          <p class="text-muted mb-0" style="font-size: var(--text-xs);">
            Vol: <%= cardStock.volume.toLocaleString('en-TZ') %>
          </p>
        <% } %>
      </div>
    </div>
  </a>
</div>
