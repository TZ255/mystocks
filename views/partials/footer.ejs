<footer class="site-footer" style="background: var(--bg-card); border-top: 1px solid var(--border-default); padding: var(--space-16) 0 var(--space-8);">
  <div class="container-hisa">
    <div class="row g-4">
      <!-- Col 1: Brand -->
      <div class="col-lg-4 col-md-6">
        <a href="/" class="text-gold fw-bold d-inline-block mb-3" style="font-size: var(--text-xl); text-decoration: none; letter-spacing: -0.03em;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block; vertical-align:middle; margin-right:6px;">
            <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline>
            <polyline points="16 7 22 7 22 13"></polyline>
          </svg>
          HisaZangu
        </a>
        <p class="text-secondary" style="font-size: var(--text-sm); line-height: var(--leading-relaxed); max-width: 320px;">
          Mfumo bora wa kufuatilia hisa zako za Soko la Hisa la Dar es Salaam.
          Pata taarifa za soko, simamia portfolio yako, na pokea arifa za bei — yote mahali pamoja.
        </p>
      </div>

      <!-- Col 2: Quick Links -->
      <div class="col-lg-4 col-md-6">
        <h6 class="text-primary fw-600 mb-3" style="font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-secondary);">Viungo vya Haraka</h6>
        <ul style="list-style: none; padding: 0; margin: 0;">
          <li class="mb-2">
            <a href="/stocks" class="text-secondary" style="font-size: var(--text-sm); transition: color var(--duration) var(--ease-out);">Hisa za DSE</a>
          </li>
          <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
            <li class="mb-2">
              <a href="/dashboard" class="text-secondary" style="font-size: var(--text-sm);">Dashboard</a>
            </li>
            <li class="mb-2">
              <a href="/portfolio" class="text-secondary" style="font-size: var(--text-sm);">Portfolio</a>
            </li>
            <li class="mb-2">
              <a href="/watchlist" class="text-secondary" style="font-size: var(--text-sm);">Watchlist</a>
            </li>
            <li class="mb-2">
              <a href="/alerts" class="text-secondary" style="font-size: var(--text-sm);">Arifa za Bei</a>
            </li>
          <% } else { %>
            <li class="mb-2">
              <a href="/auth/google" class="text-secondary" style="font-size: var(--text-sm);">Ingia na Google</a>
            </li>
          <% } %>
        </ul>
      </div>

      <!-- Col 3: Contact -->
      <div class="col-lg-4 col-md-6">
        <h6 class="text-primary fw-600 mb-3" style="font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-secondary);">Mawasiliano</h6>
        <ul style="list-style: none; padding: 0; margin: 0;">
          <li class="mb-2 d-flex align-items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-tertiary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <span class="text-secondary" style="font-size: var(--text-sm);">habari@hisazangu.co.tz</span>
          </li>
          <li class="mb-2 d-flex align-items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-tertiary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <span class="text-secondary" style="font-size: var(--text-sm);">Dar es Salaam, Tanzania</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div style="border-top: 1px solid var(--border-default); margin-top: var(--space-10); padding-top: var(--space-6);">
      <p class="text-muted text-center mb-2" style="font-size: var(--text-xs); line-height: var(--leading-relaxed);">
        <strong>Onyo:</strong> Taarifa za hisa zinatolewa kwa madhumuni ya habari tu na si ushauri wa uwekezaji. HisaZangu haikubaliani na hasara yoyote inayotokana na maamuzi ya uwekezaji. Data ya DSE inaweza kuchelewa.
      </p>
      <p class="text-muted text-center mb-0" style="font-size: var(--text-xs);">
        &copy; <%= new Date().getFullYear() %> HisaZangu. Haki zote zimehifadhiwa.
      </p>
    </div>
  </div>
</footer>
