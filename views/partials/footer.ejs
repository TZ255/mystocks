<footer class="site-footer" style="background:var(--bg-card);border-top:1px solid var(--border-default);padding:var(--space-12) 0 var(--space-6);">
  <div class="container-hisa">
    <div class="row g-4">
      <!-- Col 1: Brand -->
      <div class="col-lg-4 col-md-6">
        <a href="/" class="d-inline-flex align-items-center gap-2 mb-3" style="text-decoration:none;">
          <i class="fa-solid fa-chart-line" style="font-size: 1.2rem; color: var(--gold);" aria-hidden="true"></i>
          <span style="font-size:var(--text-lg);font-weight:800;color:var(--text-primary);letter-spacing:-0.03em;">Hisa<span style="color:var(--gold);">Zangu</span></span>
        </a>
        <p class="text-secondary" style="font-size:var(--text-sm);line-height:var(--leading-relaxed);max-width:320px;">
          Mfumo bora wa kufuatilia hisa zako za Soko la Hisa la Dar es Salaam.
          Portfolio, Watchlist, na Price Alerts — yote mahali pamoja.
        </p>
      </div>

      <!-- Col 2: Quick Links -->
      <div class="col-lg-4 col-md-6">
        <h6 class="mb-3" style="font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.08em;color:var(--text-secondary);font-weight:600;">Quick Links</h6>
        <ul style="list-style:none;padding:0;margin:0;">
          <li class="mb-2"><a href="/stocks" class="text-secondary" style="font-size:var(--text-sm);text-decoration:none;">DSE Stocks</a></li>
          <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
            <li class="mb-2"><a href="/dashboard" class="text-secondary" style="font-size:var(--text-sm);text-decoration:none;">Dashboard</a></li>
            <li class="mb-2"><a href="/portfolio" class="text-secondary" style="font-size:var(--text-sm);text-decoration:none;">Portfolio</a></li>
            <li class="mb-2"><a href="/watchlist" class="text-secondary" style="font-size:var(--text-sm);text-decoration:none;">Watchlist</a></li>
            <li class="mb-2"><a href="/alerts" class="text-secondary" style="font-size:var(--text-sm);text-decoration:none;">Price Alerts</a></li>
          <% } else { %>
            <li class="mb-2"><a href="/auth/google" class="text-secondary" style="font-size:var(--text-sm);text-decoration:none;">Sign in with Google</a></li>
          <% } %>
        </ul>
      </div>

      <!-- Col 3: Contact -->
      <div class="col-lg-4 col-md-6">
        <h6 class="mb-3" style="font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.08em;color:var(--text-secondary);font-weight:600;">Contact</h6>
        <ul style="list-style:none;padding:0;margin:0;">
          <li class="mb-2 d-flex align-items-center gap-2">
            <i class="fa-regular fa-envelope" style="font-size: 0.95rem; color: var(--text-tertiary);" aria-hidden="true"></i>
            <span class="text-secondary" style="font-size:var(--text-sm);">habari@hisazangu.com</span>
          </li>
          <li class="mb-2 d-flex align-items-center gap-2">
            <i class="fa-solid fa-location-dot" style="font-size: 0.95rem; color: var(--text-tertiary);" aria-hidden="true"></i>
            <span class="text-secondary" style="font-size:var(--text-sm);">Dar es Salaam, Tanzania</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div style="border-top:1px solid var(--border-default);margin-top:var(--space-8);padding-top:var(--space-5);">
      <p class="text-muted text-center mb-2" style="font-size:10px;line-height:var(--leading-relaxed);">
        <strong>Disclaimer:</strong> Stock information is provided for informational purposes only and does not constitute investment advice. HisaZangu is not liable for any investment decisions. DSE data may be delayed.
      </p>
      <p class="text-muted text-center mb-2" style="font-size:10px;">
        <a href="/privacy" class="text-muted" style="text-decoration:none;">Privacy Policy</a>
        <span style="margin:0 var(--space-2);">&middot;</span>
        <a href="/terms" class="text-muted" style="text-decoration:none;">Terms of Service</a>
      </p>
      <p class="text-muted text-center mb-0" style="font-size:10px;">
        &copy; <%= new Date().getFullYear() %> HisaZangu. All rights reserved.
      </p>
    </div>
  </div>
</footer>
