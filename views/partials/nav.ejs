      <div class="mobile-user-card">
        <% if (typeof user !== 'undefined' && user && user.image) { %>
          <img src="<%= user.image %>" alt="<%= user.displayName %>" class="rounded-circle" width="44" height="44" referrerpolicy="no-referrer">
        <% } else { %>
          <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:44px;height:44px;background:var(--gold);color:var(--bg-primary);font-weight:700;">
            <%= typeof user !== 'undefined' && user ? user.firstName.charAt(0) : 'U' %>
          </div>
        <% } %>
        <div>
          <p class="mb-0 fw-700" style="font-size:var(--text-sm);color:var(--text-primary);"><%= typeof user !== 'undefined' && user ? user.displayName : '' %></p>
