<%
  const moStocks = typeof stocks !== 'undefined' ? stocks : [];
  const moGainers = typeof gainers !== 'undefined' ? gainers : [];
  const moLosers = typeof losers !== 'undefined' ? losers : [];
  const moTotalVolume = typeof totalVolume !== 'undefined' ? totalVolume : 0;
  const moTotalTurnover = typeof totalTurnover !== 'undefined' ? totalTurnover : 0;
  const moTotalDeals = typeof totalDeals !== 'undefined' ? totalDeals : 0;
  const moTotalStocks = typeof totalStocks !== 'undefined' ? totalStocks : 0;
%>
<div class="market-overview">
  <!-- Stats Row -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="glass" style="border-radius:var(--border-radius);padding:var(--space-4);text-align:center;border:1px solid var(--border-default);">
        <p class="text-secondary mb-1" style="font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;">Listed Stocks</p>
        <span class="tabular-nums fw-700" style="font-size:var(--text-2xl);color:var(--gold);"><%= moTotalStocks %></span>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="glass" style="border-radius:var(--border-radius);padding:var(--space-4);text-align:center;border:1px solid var(--border-default);">
        <p class="text-secondary mb-1" style="font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;">Volume</p>
        <span class="tabular-nums fw-700" style="font-size:var(--text-2xl);color:var(--text-primary);"><%= moTotalVolume.toLocaleString('en-TZ') %></span>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="glass" style="border-radius:var(--border-radius);padding:var(--space-4);text-align:center;border:1px solid var(--border-default);">
        <p class="text-secondary mb-1" style="font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;">Turnover</p>
        <span class="tabular-nums fw-700" style="font-size:var(--text-xl);color:var(--text-primary);"><%= moTotalTurnover.toLocaleString('en-TZ') %></span>
        <span class="text-muted" style="font-size:var(--text-xs);"> TZS</span>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="glass" style="border-radius:var(--border-radius);padding:var(--space-4);text-align:center;border:1px solid var(--border-default);">
        <p class="text-secondary mb-1" style="font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.06em;">Deals</p>
        <span class="tabular-nums fw-700" style="font-size:var(--text-2xl);color:var(--text-primary);"><%= moTotalDeals.toLocaleString('en-TZ') %></span>
      </div>
    </div>
  </div>

  <!-- Gainers & Losers -->
  <div class="row g-3">
    <div class="col-md-6">
      <div class="glass" style="border-radius:var(--border-radius);padding:var(--space-5);border:1px solid var(--border-default);">
        <h6 class="d-flex align-items-center gap-2 mb-3" style="font-size:var(--text-sm);color:var(--green);font-weight:600;">
          <i class="fa-solid fa-arrow-trend-up" aria-hidden="true"></i>
          Top Gainers
        </h6>
        <% if (moGainers.length === 0) { %>
          <p class="text-muted" style="font-size:var(--text-sm);">No gainers today.</p>
        <% } else { %>
          <% moGainers.forEach(function(g) { %>
            <a href="/stocks/<%= g.symbol %>" class="d-flex justify-content-between align-items-center py-2" style="border-bottom:1px solid var(--border-default);text-decoration:none;color:var(--text-primary);">
              <span class="fw-600" style="font-size:var(--text-sm);color:var(--text-primary);"><%= g.symbol %></span>
              <div class="text-end">
                <span class="tabular-nums fw-600" style="font-size:var(--text-sm);color:var(--text-primary);"><%= g.price ? g.price.toLocaleString('en-TZ') : '0' %></span>
                <span class="tabular-nums text-green ms-2" style="font-size:var(--text-xs);">+<%= g.changePercent ? g.changePercent.toFixed(2) : '0.00' %>%</span>
              </div>
            </a>
          <% }); %>
        <% } %>
      </div>
    </div>

    <div class="col-md-6">
      <div class="glass" style="border-radius:var(--border-radius);padding:var(--space-5);border:1px solid var(--border-default);">
        <h6 class="d-flex align-items-center gap-2 mb-3" style="font-size:var(--text-sm);color:var(--red);font-weight:600;">
          <i class="fa-solid fa-arrow-trend-down" aria-hidden="true"></i>
          Top Losers
        </h6>
        <% if (moLosers.length === 0) { %>
          <p class="text-muted" style="font-size:var(--text-sm);">No losers today.</p>
        <% } else { %>
          <% moLosers.forEach(function(l) { %>
            <a href="/stocks/<%= l.symbol %>" class="d-flex justify-content-between align-items-center py-2" style="border-bottom:1px solid var(--border-default);text-decoration:none;color:var(--text-primary);">
              <span class="fw-600" style="font-size:var(--text-sm);color:var(--text-primary);"><%= l.symbol %></span>
              <div class="text-end">
                <span class="tabular-nums fw-600" style="font-size:var(--text-sm);color:var(--text-primary);"><%= l.price ? l.price.toLocaleString('en-TZ') : '0' %></span>
                <span class="tabular-nums text-red ms-2" style="font-size:var(--text-xs);"><%= l.changePercent ? l.changePercent.toFixed(2) : '0.00' %>%</span>
              </div>
            </a>
          <% }); %>
        <% } %>
      </div>
    </div>
  </div>
</div>
